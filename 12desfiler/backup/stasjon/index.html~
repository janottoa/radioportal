<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administrer Radiostasjoner</title>
    <style>
        label { display: block; margin-top: 10px; }
        button { margin-top: 10px; }
        .category-header { font-size: 1.2em; font-weight: bold; margin-top: 20px; }
    </style>
</head>
<body>

<h1>Administrer Radiostasjoner</h1>

<form id="stationForm">
    <input type="hidden" id="stationIndex" value="-1">
    
    <label for="stationCategory">Kategori:</label>
    <input type="text" id="stationCategoryInput" required>

    <label for="stationName">Navn:</label>
    <input type="text" id="stationName" required>

    <label for="stationUrl">URL:</label>
    <input type="text" id="stationUrl" required>

    <label for="stationLogo">Logo (URL til katalog eller bilde):</label>
    <input type="text" id="stationLogo">

    <label for="stationInfo">Informasjon:</label>
    <input type="text" id="stationInfo">

    <label for="stationChannelUrl">Kanalens URL:</label>
    <input type="text" id="stationChannelUrl">

    <button type="button" onclick="addOrUpdateStation()">Legg til / Oppdater</button>
</form>

<h2>Stasjonsliste</h2>
<div id="stationList"></div>

<script>
    let stations = {};

    async function loadStations() {
        try {
            const response = await fetch('../stations.json');
            if (!response.ok) throw new Error('Network response was not ok');
            stations = await response.json();
            displayStations();
        } catch (error) {
            console.error('Feil ved innlasting av stasjoner:', error);
            alert('Kunne ikke laste stasjoner fra stations.json');
        }
    }

    async function saveStationsToFile() {
        try {
            const response = await fetch('../stations', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(stations)
            });
            const message = await response.text();
            console.log(message); // Bekreftelse på at lagring er vellykket
        } catch (error) {
            console.error('Kunne ikke lagre til fil:', error);
        }
    }

    function displayStations() {
        const stationList = document.getElementById('stationList');
        stationList.innerHTML = '';
        
        // Vis stasjoner gruppert etter kategori
        for (const [category, stationsInCategory] of Object.entries(stations)) {
            const categoryHeader = document.createElement('div');
            categoryHeader.className = 'category-header';
            categoryHeader.textContent = category;
            stationList.appendChild(categoryHeader);

            const categoryList = document.createElement('ul');
            stationsInCategory.forEach((station, index) => {
                const listItem = document.createElement('li');
                listItem.innerHTML = `
                    <strong>${station.name}</strong>
                    <br>URL: ${station.url} 
                    <br>Logo: ${station.logo}
                    <br>Informasjon: ${station.songInfo || 'Ingen info tilgjengelig'}
                    <br>Kanalens URL: ${station.channelUrl || 'Ikke tilgjengelig'}
                    <br>
                    <button onclick="editStation('${category}', ${index})">Endre</button>
                    <button onclick="deleteStation('${category}', ${index})">Slett</button>
                    <button onclick="moveStation('${category}', ${index}, -1)">Flytt opp</button>
                    <button onclick="moveStation('${category}', ${index}, 1)">Flytt ned</button>
                `;
                categoryList.appendChild(listItem);
            });
            stationList.appendChild(categoryList);
        }
    }

    function addOrUpdateStation() {
        const category = document.getElementById('stationCategoryInput').value;
        const name = document.getElementById('stationName').value;
        const url = document.getElementById('stationUrl').value;
        const logo = document.getElementById('stationLogo').value;
        const info = document.getElementById('stationInfo').value;
        const channelUrl = document.getElementById('stationChannelUrl').value;
        const stationData = { name, url, logo, songInfo: info, channelUrl };

        if (!stations[category]) stations[category] = [];
        const index = parseInt(document.getElementById('stationIndex').value, 10);
        if (index === -1) {
            stations[category].push(stationData);
        } else {
            stations[category][index] = stationData;
        }

        displayStations();
        resetForm();

        // Lagre til fil
        saveStationsToFile();
    }

    function editStation(category, index) {
        const station = stations[category][index];
        
        document.getElementById('stationCategoryInput').value = category;
        document.getElementById('stationName').value = station.name;
        document.getElementById('stationUrl').value = station.url;
        document.getElementById('stationLogo').value = station.logo;
        document.getElementById('stationInfo').value = station.songInfo;
        document.getElementById('stationChannelUrl').value = station.channelUrl;
        
        const stationIndexElement = document.getElementById('stationIndex');
        if (stationIndexElement) {
            stationIndexElement.value = index; // Setter index for redigering
        } else {
            console.error("Element med id 'stationIndex' finnes ikke");
        }
    }

    function deleteStation(category, index) {
        stations[category].splice(index, 1);
        if (stations[category].length === 0) delete stations[category]; // Fjern kategori hvis tom
        displayStations();
        saveStationsToFile();
    }

    function moveStation(category, index, direction) {
        const newIndex = index + direction;
        if (newIndex >= 0 && newIndex < stations[category].length) {
            // Bytt plass på elementene
            const [movedStation] = stations[category].splice(index, 1);
            stations[category].splice(newIndex, 0, movedStation);
            displayStations();
            saveStationsToFile();
        }
    }

    function resetForm() {
        document.getElementById('stationForm').reset();
        document.getElementById('stationIndex').value = -1; // Tilbakestill index
    }

    window.onload = loadStations;
</script>

</body>
</html>
