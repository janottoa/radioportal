    let currentAudio = null;
    let currentlyPlayingUrl = null;

    async function fetchStreamUrlFromXSPF(xspfUrl) {
        try {
            const response = await fetch(xspfUrl);
            const xspfContent = await response.text();
            const parser = new DOMParser();
            const xmlDoc = parser.parseFromString(xspfContent, 'application/xml');
            const locationElement = xmlDoc.querySelector('location');
            return locationElement ? locationElement.textContent.trim() : null;
        } catch (error) {
            console.error('Feil ved henting av XSPF-URL:', error);
            return null;
        }
    }

    async function togglePlayStation(url, stationDiv) {
        const category = stationDiv.getAttribute("data-category");
        const station = stationsData[category].find(s => s.url === url);

        if (currentAudio && url === currentlyPlayingUrl) {
            currentAudio.pause();
            currentlyPlayingUrl = null;
            stationDiv.classList.remove('playing');
            updateFooter(null);
        } else {
            if (currentAudio) currentAudio.pause();

            let actualStreamUrl = url.endsWith('.xspf') ? await fetchStreamUrlFromXSPF(url) : url;
            if (!actualStreamUrl) {
                alert("Strømmen er ikke tilgjengelig.");
                return;
            }

            currentAudio = new Audio(actualStreamUrl);
            currentAudio.play();
            currentlyPlayingUrl = url;

            document.querySelectorAll('.station').forEach(st => st.classList.remove('playing'));
            stationDiv.classList.add('playing');
            updateFooter(station);
        }
    }

    function updateFooter(station) {
        const logoElement = document.getElementById('station-logo');
        const channelNameElement = document.getElementById('channel-name');
        const songInfoElement = document.getElementById('song-info');

        if (station) {
            logoElement.src = station.logo;
            logoElement.style.display = "inline";
            channelNameElement.textContent = station.name;
            songInfoElement.textContent = station.songInfo || "";
        } else {
            logoElement.style.display = "none";
            channelNameElement.textContent = "Velg en radiokanal";
            songInfoElement.textContent = "";
        }
    }

    function showStations(category) {
        const stationsGrid = document.getElementById('stations-grid');
        stationsGrid.innerHTML = '';
        stationsData[category].forEach(station => {
            const stationDiv = document.createElement('div');
            stationDiv.classList.add('station');
            stationDiv.setAttribute("data-category", category);
            stationDiv.onclick = () => togglePlayStation(station.url, stationDiv);

            const logo = document.createElement('img');
            logo.src = station.logo;
            logo.alt = `${station.name} logo`;
            stationDiv.appendChild(logo);

            const name = document.createElement('h3');
            name.textContent = station.name;
            stationDiv.appendChild(name);

            stationsGrid.appendChild(stationDiv);
        });
    }

