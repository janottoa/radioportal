            <img id="station-logo" src="" alt="Stasjonslogo" style="display:none; height: 30px; margin-right: 10px;">
            <span id="channel-name">Velg en radiokanal</span> 
            <span id="song-info"></span>
        </div>
    </div>

    <script>
        function refreshPage() {
            window.location.reload();
        }

        function toggleDayMode() {
            document.body.classList.toggle('day-mode');
        }

        const sidebar = document.getElementById("sidebar");
        const stationsGrid = document.getElementById("stations-grid");
        const screenshotResultDiv = document.createElement('div');
        screenshotResultDiv.id = 'screenshotResult';
        stationsGrid.appendChild(screenshotResultDiv);

        const menus = {
            main: [
                { label: "NRK", action: () => showStations("NRK") },
                { label: "P4", action: () => showStations("P4") },
                { label: "Radio Norge", action: () => showStations("Radio Norge") },
                { label: "Metro", action: () => showStations("Metro") },
                { label: "Lokale", action: () => showStations("Lokale") },
                { label: "Internet", action: () => showStations("Internet") },
                { label: "1fm", action: () => showStations("1fm") },
                { label: "Latinske", action: () => showStations("Latinske") },
                { label: "Mer...", action: () => loadMenu("extra") },
                { label: "Tilbake", action: () => loadMenu("main") },
            ],
            extra: [
                { label: "Klassisk", action: () => showStations("Klassisk") },
                { label: "Rock", action: () => showStations("Rock") },
                { label: "Jazz", action: () => showStations("Jazz") },
                { label: "Pop", action: () => showStations("Pop") },
                { label: "Tilbake", action: () => loadMenu("main") },
            ],
        };

        function loadMenu(menuName) {
            sidebar.innerHTML = "";
            menus[menuName].forEach((item) => {
                const button = document.createElement("button");
                button.textContent = item.label;
                button.onclick = item.action;
                sidebar.appendChild(button);
            });
        }
        
        // Kall på loadMenu for å laste hovedmenyen ved start
        loadMenu('main');

        let stationsData = {};
        let currentAudio = null;
        let currentlyPlayingUrl = null;

        // Definer URL basert på nettverkssituasjonen
        let url;
        if (window.location.hostname.startsWith('192.168.') || window.location.hostname === 'localhost') {
            url = 'http://192.168.0.11/stations.json';
        } else {
            url = 'http://anthonsen.net:2222/stations.json';
        }

        // Last stationsData fra JSON-fil
        fetch(url)
            .then(response => {
                if (response.ok) {
                    return response.json();
                } else {
                    throw new Error(`Network response was not ok: ${response.statusText}`);
                }
            })
            .then(data => {
                stationsData = data;
                showStations('NRK'); // Viser NRK-stasjoner som standard
            })
            .catch(error => console.error('Fetch error:', error));

        async function fetchScreenshot(channelUrl) {
            try {
                const apiKey = 'ccbafb090b785be9628134029e5d8fa4';
                const timestamp = new Date().getTime(); // Legg til tidsstempel for å unngå caching
                const screenshotUrl = `https://api.screenshotlayer.com/api/capture?access_key=${apiKey}&url=${encodeURIComponent(channelUrl)}&timestamp=${timestamp}`;
                return screenshotUrl;
            } catch (error) {
                console.error('Feil ved henting av skjermbilde:', error);
                return null;
            }
        }

        async function showIframeScreenshot(channelUrl) {
            screenshotResultDiv.innerHTML = ''; // Tøm eksisterende skjermbilde

            const screenshotUrl = await fetchScreenshot(channelUrl);
            if (screenshotUrl) {
                const img = document.createElement('img');
                img.src = screenshotUrl;
                img.alt = 'Skjermbilde av kanalen';
                screenshotResultDiv.appendChild(img);
                screenshotResultDiv.style.display = 'flex';
            } else {
                screenshotResultDiv.style.display = 'none';
            }
        }

        function showStations(category, selectedStation = null) {
            stationsGrid.innerHTML = ''; screenshotResultDiv.innerHTML = ''; screenshotResultDiv.style.display = 'none'; // Tøm tidligere innhold
            stationsGrid.appendChild(screenshotResultDiv); // Legg tilbake screenshot-diven

            // Vis alle stasjoner i valgt kategori
            if (stationsData[category]) {
                stationsData[category].forEach(station => {
                    const stationDiv = document.createElement('div');
                    stationDiv.classList.add('station');
                    stationDiv.setAttribute("data-category", category);
                    stationDiv.setAttribute("data-url", station.url);
                    stationDiv.onclick = () => {
                        togglePlayStation(station.url, stationDiv);
                        if (station.channelUrl) {
                            showIframeScreenshot(station.channelUrl);
                        }
                    };

                    const logo = document.createElement('img');
                    logo.src = station.logo;
                    logo.alt = `${station.name} logo`;
                    stationDiv.appendChild(logo);

                    const name = document.createElement('h3');
                    name.textContent = station.name;
                    stationDiv.appendChild(name);

                    stationsGrid.appendChild(stationDiv);
                });
            }

            // Hvis en stasjon er valgt
            if (selectedStation) {
                initializeAudio(selectedStation.url);
                updateFooter(selectedStation);
                if (selectedStation.channelUrl) {
                    showIframeScreenshot(selectedStation.channelUrl);
                } else {
                    screenshotResultDiv.innerHTML = ''; // Fjern skjermbilde hvis ikke tilgjengelig
                    screenshotResultDiv.style.display = 'none';
                }
            }
        }

            // Vis alle stasjoner i valgt kategori
            if (stationsData[category]) {
                stationsData[category].forEach(station => {
                    const stationDiv = document.createElement('div');
                    stationDiv.classList.add('station');
                    stationDiv.setAttribute("data-category", category);
                    stationDiv.setAttribute("data-url", station.url);
                    stationDiv.onclick = () => togglePlayStation(station.url, stationDiv);

                    const logo = document.createElement('img');
                    logo.src = station.logo;
                    logo.alt = `${station.name} logo`;
                    stationDiv.appendChild(logo);

                    const name = document.createElement('h3');
                    name.textContent = station.name;
                    stationDiv.appendChild(name);

                    stationsGrid.appendChild(stationDiv);
                });
            }

            // Hvis en stasjon er valgt
            if (selectedStation) {
                initializeAudio(selectedStation.url);

                // Oppdater footer med stasjonsinformasjon
                updateFooter(selectedStation);

                // Hvis kanalen har en nettside, vis skjermbilde
                if (selectedStation.channelUrl) {
                    showIframeScreenshot(selectedStation.channelUrl);
                } else {
                    screenshotResultDiv.innerHTML = ''; // Fjern skjermbilde hvis ikke tilgjengelig
                    screenshotResultDiv.style.display = 'none';
                }
            }
        }

        async function initializeAudio(url) {
            if (currentAudio) {
                currentAudio.pause();
            }

            currentAudio = new Audio(url);
            currentAudio.muted = true;
            currentlyPlayingUrl = url;

            currentAudio.addEventListener('canplay', () => {
                currentAudio.muted = false;
                currentAudio.play().catch(error => {
                    console.error("Automatisk avspilling ble blokkert:", error);
                });
            });

            setupWebSocket(url);
        }

        function setupWebSocket(url) {
            if (window.ws) {
                window.ws.close();
            }

            window.ws = new WebSocket('ws://anthonsen.net:8080');
            window.ws.onopen = () => {
                window.ws.send(JSON.stringify({ action: 'start', streamUrl: url }));
            };
            window.ws.onmessage = (event) => { const data = JSON.parse(event.data); updateSongInfo(data.StreamTitle, data.imageUrl); updateFooter(currentlyPlayingStation); };
            window.ws.onerror = (error) => {
                console.error("WebSocket-feil:", error);
                updateSongInfo("Ingen metadata tilgjengelig");
            };
            window.ws.onclose = () => {
                console.log("WebSocket-tilkobling lukket");
            };
        }

        function updateSongInfo(songTitle, imageUrl) {
            const songInfoElement = document.getElementById('song-info');
            const channelNameElement = document.getElementById('channel-name');
            if (songTitle) {
                songInfoElement.textContent = ` - ${songTitle}`;
            } else {
                songInfoElement.textContent = "";
            }
            if (imageUrl) {
                const logoElement = document.getElementById('station-logo');
                logoElement.src = imageUrl;
                logoElement.style.display = "inline";
            }
            document.title = `${channelNameElement.textContent} ${songInfoElement.textContent}`;
        }

        function updateFooter(station) {
            const logoElement = document.getElementById('station-logo');
            const channelNameElement = document.getElementById('channel-name');
            const songInfoElement = document.getElementById('song-info');

            if (station) {
                logoElement.src = station.logo;
                logoElement.style.display = "inline";
                channelNameElement.textContent = station.name;
                songInfoElement.textContent = station.songInfo || "";
            } else {
                logoElement.style.display = "none";
                channelNameElement.textContent = "Velg en radiokanal";
                songInfoElement.textContent = "";
            }
        }
    </script>
</body>
</html>
