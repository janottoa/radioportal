async function togglePlayStation(url, stationDiv) {
    const category = stationDiv.getAttribute("data-category");
    const station = category === "Favoritter"
        ? (JSON.parse(localStorage.getItem("favorites")) || []).find(fav => fav.url === url)
        : stationsData[category]?.find(s => s.url === url);

    if (!station) {
        console.error("Stasjon ikke funnet i kategorien:", category, "URL:", url);
        return;
    }

    console.log("Spiller av stasjon:", station);

    // Hvis stasjonen allerede spiller
    if (currentAudio && url === currentlyPlayingUrl) {
        currentAudio.pause();
        currentlyPlayingUrl = null;
        stationDiv.classList.remove('logo-playing', 'playing');
        stationDiv.style.backgroundImage = ''; // Fjern bakgrunn
        updateFooter(null);
        localStorage.removeItem('lastStation');
        return;
    }

    // Hvis en annen stasjon spiller, stopp den
    if (currentAudio) currentAudio.pause();

    // Oppdater spillerstatus
    document.querySelectorAll('.station').forEach(div => {
        div.classList.remove('playing', 'logo-playing');
        div.style.backgroundImage = '';
    });

    // Marker spillende stasjon
    stationDiv.classList.add('logo-playing');
    stationDiv.style.backgroundImage = `url('${station.logo}')`;

    // Initialiser lydstrømmen
    currentAudio = new Audio(url);
    currentAudio.muted = true;
    currentlyPlayingUrl = url;

    currentAudio.addEventListener('canplay', () => {
        currentAudio.muted = false;
        currentAudio.play().catch(error => {
            console.error("Automatisk avspilling ble blokkert:", error);
        });
        updateFooter(station);
        localStorage.setItem('lastStation', JSON.stringify({ url, category }));
    });

    setupWebSocket(url);
}

function isFavorite(url) {
    const favorites = JSON.parse(localStorage.getItem("favorites")) || [];
    return favorites.some(fav => fav.url === url);
}

