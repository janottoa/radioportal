   let stationsData = {};
let currentAudio = null;
let currentlyPlayingUrl = null;
let currentPlayingStation = null; // Holder oversikt over spillende stasjon

// Definer URL basert på nettverkssituasjonen
let url;
if (window.location.hostname.startsWith('192.168.') || window.location.hostname === 'localhost') {
    url = 'http://192.168.0.11/stations.json';
} else {
    url = 'http://anthonsen.net:2222/stations.json';
}

// Last stationsData fra JSON-fil
fetch(url)
    .then(response => {
        if (response.ok) {
            return response.json();
        } else {
            throw new Error(`Network response was not ok: ${response.statusText}`);
        }
    })
    .then(data => {
        stationsData = data;
        const lastStation = JSON.parse(localStorage.getItem('lastStation'));
        if (lastStation) {
            const category = lastStation.category;
            const url = lastStation.url;
            showStations(category);
            setTimeout(() => {
                const stationDiv = Array.from(document.querySelectorAll('.station')).find(div =>
                    div.getAttribute("data-category") === category && div.getAttribute("data-url") === url
                );
                if (stationDiv) {
                    initializeAudio(url, stationDiv);
                }
            }, 1000);
        } else {
            showStations('NRK'); // Viser NRK-stasjoner som standard
        }
    })
    .catch(error => console.error('Fetch error:', error));

function initializeAudio(url, stationDiv, station = null, useLogoBackground = false) {
    if (!station) {
        // Hvis stasjonsdata ikke er gitt, hent det fra stationsData
        const category = stationDiv.getAttribute("data-category");
        const stationUrl = stationDiv.getAttribute("data-url");
        const categoryStations = stationsData[category];
        station = categoryStations?.find(s => s.url === stationUrl);
    }

    if (!station) {
        console.error("Stasjon mangler for URL:", url);
        return;
    }

    console.log("Starter avspilling for stasjon:", station);

    // Tilbakestill alle stasjoner
    document.querySelectorAll('.station').forEach(div => {
        div.classList.remove('logo-only', 'playing');
        div.style.backgroundImage = ''; // Fjern eventuell bakgrunn
    });

    // Marker stasjonen som spilles av
    if (useLogoBackground && station.logo) {
        stationDiv.classList.add('logo-only');
        stationDiv.style.backgroundImage = `url('${station.logo}')`;
    } else {
        stationDiv.classList.add('playing');
    }
    currentPlayingStation = stationDiv; // Oppdater spillende stasjon

    // Opprett eller oppdater lydobjektet
    if (currentAudio) {
        currentAudio.pause();
    }
    currentAudio = new Audio(url);
    currentAudio.play()
        .then(() => {
            console.log("Avspilling startet for:", station.name);
            updateFooter(station); // Oppdater footer med metadata
        })
        .catch(error => {
            console.error("Kunne ikke spille av stasjonen:", error);
            alert("Kunne ikke spille av stasjonen. Sjekk nettverk og URL.");
        });
}

function stopStation() {
    if (currentPlayingStation) {
        currentPlayingStation.classList.remove('playing');
        const favoriteButton = currentPlayingStation.querySelector('.favorite-button');
        if (favoriteButton) {
            favoriteButton.style.display = 'inline-block'; // Vis favorittknappen for den stoppede stasjonen
        }
        currentPlayingStation = null;
    }

    if (currentAudio) {
        currentAudio.pause();
        currentAudio = null;
    }

    console.log("Avspilling stoppet");
}


