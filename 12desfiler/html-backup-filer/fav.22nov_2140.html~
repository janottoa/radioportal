        function updateSongInfo(songTitle, imageUrl) {
            const songInfoElement = document.getElementById('song-info');
            songInfoElement.textContent = songTitle || "";
            const logoElement = document.getElementById('station-logo');
            if (imageUrl) {
                logoElement.src = imageUrl;
                logoElement.style.display = "inline";
            }
            const stationName = document.getElementById('channel-name').textContent;
            document.title = `${stationName} - ${songTitle || ''}`;
        }

     function updateFooter(station) {
    const logoElement = document.getElementById("station-logo");
    /*const channelNameElement = document.getElementById("channel-name"); */
    const songInfoElement = document.getElementById("song-info");

    if (station) {
        // Hvis logo mangler, hent stasjonen fra stationsData
        if (!station.logo && station.category && station.url) {
            const categoryStations = stationsData[station.category];
            const fullStation = categoryStations?.find(s => s.url === station.url);
            if (fullStation) {
                station.logo = fullStation.logo; // Oppdater logoen
                /* station.name = fullStation.name; // Oppdater navnet  */
            }
        }

        // Oppdater logo
        if (station.logo) {
            logoElement.src = station.logo;
            logoElement.style.display = "inline";
        } else {
            console.warn("Ingen logo funnet for stasjonen:", station);
            logoElement.style.display = "none";
        }

        // Oppdater navn
        channelNameElement.textContent = station.name || "Ukjent stasjon";
        songInfoElement.textContent = station.songInfo || "";
    } else {
        // Tilbakestill når ingen stasjon er valgt
        logoElement.style.display = "none";
        /* channelNameElement.textContent = "Velg en radiokanal"; */
        songInfoElement.textContent = "";
