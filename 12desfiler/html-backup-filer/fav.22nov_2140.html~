function applySystemTheme() {
    const prefersDarkScheme = window.matchMedia("(prefers-color-scheme: dark)");
    
    if (prefersDarkScheme.matches) {
        document.body.classList.remove('day-mode'); // Fjern dagmodus
    } else {
        document.body.classList.add('day-mode'); // Sett dagmodus
    }
}

// Overvåk endringer i systemets lysmodus
